<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="28dp"
    tools:context=".MainActivity">

    <!-- Language Selector Button (Top Right) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_language"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🇫🇷 FR ▾"
        android:textColor="@color/text_secondary"
        style="@style/Widget.Material3.Button.TextButton"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- Centered Menu Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/primary_color"
            android:textSize="40sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="56dp" />

        <!-- Play Button (Primary) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_play"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_play"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/primary_color"
            app:cornerRadius="16dp"
            app:elevation="2dp" />

        <!-- Highscore Button (Secondary) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_highscore"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_highscore"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/button_secondary_background"
            app:cornerRadius="16dp"
            app:elevation="0dp" />

        <!-- About Button (Tertiary) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_about"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="@string/btn_about"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/button_secondary_background"
            app:cornerRadius="16dp"
            app:elevation="0dp" />

    </LinearLayout>

    <!-- Small Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Version 1.0"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
